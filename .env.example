AGAPORNIS_SERVERS_DIR=/var/lib/agapornis/servers
AGAPORNIS_DOCKER_NETWORK=agapornis_ntw
AGAPORNIS_BACKUP_ENCRYPTION_KEY=
AGAPORNIS_BACKUP_CONCURRENCY=1
AGAPORNIS_PROTECTION_SCAN_SECONDS=10
AGAPORNIS_DISK_CHECK_SECONDS=150
AGAPORNIS_S3_BUCKET=
