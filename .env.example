AGAPORNIS_SERVERS_DIR=/var/lib/agapornis/servers
AGAPORNIS_DOCKER_NETWORK=agapornis_ntw
AGAPORNIS_BACKUP_ENCRYPTION_KEY=
AGAPORNIS_BACKUP_CONCURRENCY=1
AGAPORNIS_PROTECTION_SCAN_SECONDS=10
AGAPORNIS_DISK_CHECK_SECONDS=150
# Console readers exist only while viewed and for this idle grace period.
AGAPORNIS_CONSOLE_READER_IDLE_SECONDS=120
# Hard resource ceilings for console streams and retained history.
AGAPORNIS_CONSOLE_MAX_ACTIVE_READERS=256
AGAPORNIS_CONSOLE_HISTORY_TOTAL_BYTES=67108864
AGAPORNIS_S3_BUCKET=
AGAPORNIS_S3_REGION=us-east-1
AGAPORNIS_S3_ENDPOINT=
AGAPORNIS_S3_PREFIX=agapornis
AGAPORNIS_CROWDSEC_ENABLED=false
# Leave as cscli for PATH lookup plus common Linux install-path fallback.
AGAPORNIS_CROWDSEC_CLI_PATH=cscli
AGAPORNIS_CROWDSEC_MAX_ALERTS=100
# Enable only when systemd supervises the agent with the supplied unit.
AGAPORNIS_UPDATE_AUTO_RESTART=true
AGAPORNIS_UPDATE_SYSTEMD_SERVICE=agapornis-agent.service
# Seconds the newly activated binary must remain healthy before the old copy is removed.
AGAPORNIS_UPDATE_HEALTH_SECONDS=30
